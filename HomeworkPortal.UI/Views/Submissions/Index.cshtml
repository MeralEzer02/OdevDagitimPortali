@{
    ViewData["Title"] = "Ödev Teslimleri";
    var role = ViewBag.Role as string;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-check-square mr-2 text-primary"></i>Teslim Yönetimi
    </h1>

    @if (role == "Student")
    {
        <button class="d-none d-sm-inline-block btn btn-sm btn-success shadow-sm" id="btnOpenUploadModal" style="display:none !important;">
            <i class="fas fa-upload fa-sm text-white-50 mr-2"></i> Ödev Yükle
        </button>
    }
</div>

<div class="card shadow mb-4">
    <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between">
        <h6 class="m-0 font-weight-bold text-primary" id="pageSubtitle">Ödev Teslimleri Yükleniyor...</h6>
    </div>
    <div class="card-body">
        <div class="table-responsive">
            <table class="table table-bordered table-hover align-middle mb-0" width="100%" cellspacing="0">
                <thead class="thead-dark">
                    <tr>
                        @if (role == "Teacher" || role == "Admin")
                        {
                            <th>Öğrenci Adı</th>
                        }
                        else
                        {
                            <th>Ödev Başlığı</th>
                        }
                        <th>Dosya</th>
                        <th>Öğrenci Notu (Açıklama)</th>
                        <th>Yükleme Tarihi</th>
                        <th>Not (Puan)</th>
                        <th>İşlem</th>
                    </tr>
                </thead>
                <tbody id="submissionTableBody">
                    <tr><td colspan="6" class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Veriler Yükleniyor...</td></tr>
                </tbody>
            </table>
        </div>

        <!-- Sayfalama (Pagination) Alt Yapısı -->
        <div class="d-flex justify-content-between align-items-center mt-3 px-2">
            <div id="pageInfo" class="small font-weight-bold text-muted"></div>
            <nav aria-label="Page navigation">
                <ul class="pagination pagination-sm mb-0" id="paginationContainer"></ul>
            </nav>
        </div>
    </div>
</div>

@* Ödev Yükleme Modalı (Sadece Öğrenci) *@
@if (role == "Student")
{
    <div class="modal fade" id="uploadModal" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-success text-white">
                    <h5 class="modal-title">Ödev Dosyasını Yükle</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <form id="uploadForm">
                        <input type="hidden" id="uploadAssignmentId">
                        <div class="form-group">
                            <label class="font-weight-bold">Dosya (PDF, DOCX, ZIP, RAR - Max 5MB)</label>
                            <input type="file" id="submissionFile" class="form-control-file" required accept=".pdf,.doc,.docx,.zip,.rar">
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Öğretmene Notun (Opsiyonel)</label>
                            <textarea id="submissionNote" class="form-control" rows="3" placeholder="Ödevle ilgili eklemek istediklerinizi yazabilirsiniz..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-success btn-block" id="btnUploadSubmit">Dosyayı Gönder</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@* Notlandırma Modalı (Teacher / Admin) *@
@if (role == "Teacher" || role == "Admin")
{
    <div class="modal fade" id="gradeModal" data-backdrop="static" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">Ödevi Notlandır</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close"><span aria-hidden="true">&times;</span></button>
                </div>
                <div class="modal-body">
                    <form id="gradeForm">
                        <input type="hidden" id="gradeSubmissionId">
                        <div class="form-group">
                            <label class="font-weight-bold">Verilecek Not (0-100)</label>
                            <input type="number" id="gradeValue" class="form-control" required min="0" max="100">
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Geri Bildirim (Açıklama)</label>
                            <textarea id="gradeFeedback" class="form-control" rows="3" placeholder="Öğrenciye iletilecek değerlendirme notu..."></textarea>
                        </div>
                        <button type="submit" class="btn btn-warning btn-block font-weight-bold" id="btnGradeSubmit">Puanı Kaydet</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/locale/tr.min.js"></script>

    <script>
        const API_BASE = "https://localhost:7113/api/Submissions";
        const USER_ROLE = "@role";

        const urlParams = new URLSearchParams(window.location.search);
        const ASSIGNMENT_ID = urlParams.get('assignmentId');

        let currentPage = 1;
        const pageSize = 10;
        let globalSubmissions = [];

        $(document).ready(function () {
            moment.locale('tr');

            checkContextAndLoad();

            if (USER_ROLE === "Student") {
                handleUploadForm();

                if(ASSIGNMENT_ID) {
                    $("#btnOpenUploadModal").show().click(function() {
                        $("#uploadAssignmentId").val(ASSIGNMENT_ID);
                        $("#uploadModal").modal("show");
                    });
                }
            }

            if (USER_ROLE === "Teacher" || USER_ROLE === "Admin") {
                handleGradeForm();
            }
        });

        function checkContextAndLoad() {
            if (USER_ROLE === "Student") {
                $("#pageSubtitle").text("Benim Yüklediğim Tüm Ödevler");
                loadSubmissions(1);
            } else {
                if (ASSIGNMENT_ID) {
                    $("#pageSubtitle").text("Seçili Ödevin Teslim Listesi");
                    loadSubmissions(1);
                } else {
                    $("#submissionTableBody").html(`<tr><td colspan="6" class="text-center text-warning py-4">Lütfen önce <b>Ödevler</b> sayfasından teslimlerini görmek istediğiniz bir ödevi seçin.</td></tr>`);
                    $("#pageSubtitle").text("Ödev Seçilmedi");
                }
            }
        }

        function loadSubmissions(page) {
            currentPage = page;

            let endpoint = USER_ROLE === "Student"
                ? `${API_BASE}/student?pageNumber=${page}&pageSize=${pageSize}`
                : `${API_BASE}/assignment/${ASSIGNMENT_ID}?pageNumber=${page}&pageSize=${pageSize}`;

            $.ajax({
                url: endpoint,
                method: "GET",
                beforeSend: function () {
                    $("#submissionTableBody").css("opacity", "0.5");
                },
                success: function (res) {
                    const data = res.data || res || [];
                    globalSubmissions = data;

                    renderTable(data);
                    renderPagination(res.totalCount || 0, res.pageNumber || 1, res.totalPages || 1);
                },
                error: function () {
                    $("#submissionTableBody").html('<tr><td colspan="6" class="text-center text-danger py-4">Veriler çekilirken bir hata oluştu.</td></tr>');
                },
                complete: function() {
                    $("#submissionTableBody").css("opacity", "1");
                }
            });
        }

        function renderTable(data) {
            if (data.length === 0) {
                $("#submissionTableBody").html('<tr><td colspan="6" class="text-center text-muted py-4">Henüz bir teslim kaydı bulunmuyor.</td></tr>');
                return;
            }

            let html = "";
            data.forEach(item => {
                const dateText = moment(item.submittedAt).format('DD.MM.YYYY HH:mm');
                const fileLink = item.filePath
                    ? `<a href="https://localhost:7113/${item.filePath}" target="_blank" class="btn btn-sm btn-outline-info"><i class="fas fa-download mr-1"></i>İndir</a>`
                    : '-';

                let gradeHtml = "";
                if (item.grade !== null && item.grade !== undefined) {
                    gradeHtml = `<span class="badge badge-success p-2">Not: ${item.grade}</span>`;
                    if(item.feedback) gradeHtml += `<div class="small text-muted mt-1">${item.feedback}</div>`;
                } else {
                    gradeHtml = `<span class="badge badge-warning text-dark p-2">Bekliyor</span>`;
                }

                html += `<tr>`;

                if (USER_ROLE === "Teacher" || USER_ROLE === "Admin") {
                    html += `<td><strong>${item.studentFullName || 'Öğrenci'}</strong></td>`;
                } else {
                    html += `<td><strong>${item.assignmentTitle || 'Ödev'}</strong></td>`;
                }

                html += `
                    <td>${fileLink}</td>
                    <td class="text-muted small">${item.studentNote || '-'}</td>
                    <td>${dateText}</td>
                    <td>${gradeHtml}</td>
                    <td>${renderActions(item)}</td>
                </tr>`;
            });

            $("#submissionTableBody").html(html);
        }

        function renderActions(item) {
            let actions = "";
            if (USER_ROLE === "Teacher" || USER_ROLE === "Admin") {
                actions += `<button class="btn btn-sm btn-warning font-weight-bold" onclick="openGradeModal(${item.id})"><i class="fas fa-star mr-1"></i>Puan Ver</button>`;
            } else {
                actions += `<span class="text-muted small"><i class="fas fa-info-circle mr-1"></i>Sadece Görüntüleme</span>`;
            }
            return actions;
        }

        function renderPagination(totalCount, current, totalPages) {
            if (totalPages <= 1) {
                $("#paginationContainer, #pageInfo").empty();
                return;
            }

            let html = `<li class="page-item ${current === 1 ? 'disabled' : ''}"><a class="page-link" href="javascript:void(0)" onclick="loadSubmissions(${current - 1})">Önceki</a></li>`;
            for (let i = 1; i <= totalPages; i++) {
                html += `<li class="page-item ${i === current ? 'active' : ''}"><a class="page-link" href="javascript:void(0)" onclick="loadSubmissions(${i})">${i}</a></li>`;
            }
            html += `<li class="page-item ${current === totalPages ? 'disabled' : ''}"><a class="page-link" href="javascript:void(0)" onclick="loadSubmissions(${current + 1})">Sonraki</a></li>`;

            $("#paginationContainer").html(html);
            const startItem = (current - 1) * pageSize + 1;
            const endItem = Math.min(current * pageSize, totalCount);
            $("#pageInfo").text(`Toplam ${totalCount} kayıttan ${startItem}-${endItem} arası gösteriliyor.`);
        }

        function handleUploadForm() {
            $("#uploadForm").on("submit", function (e) {
                e.preventDefault();

                let formData = new FormData();
                formData.append("AssignmentId", $("#uploadAssignmentId").val());
                formData.append("StudentNote", $("#submissionNote").val());

                let fileInput = $("#submissionFile")[0].files[0];
                if (fileInput) formData.append("File", fileInput);

                const btn = $("#btnUploadSubmit");
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Yükleniyor...');

                $.ajax({
                    url: API_BASE,
                    method: "POST",
                    data: formData,
                    processData: false,
                    contentType: false,
                    success: function () {
                        $("#uploadModal").modal("hide");
                        $("#uploadForm")[0].reset();
                        Swal.fire('Harika!', 'Ödev dosyanız başarıyla yüklendi.', 'success');
                        loadSubmissions(1);
                    },
                    complete: function () {
                        btn.prop("disabled", false).text("Dosyayı Gönder");
                    }
                });
            });
        }

        function handleGradeForm() {
            $("#gradeForm").on("submit", function (e) {
                e.preventDefault();
                const subId = $("#gradeSubmissionId").val();
                const data = {
                    grade: parseInt($("#gradeValue").val()),
                    feedback: $("#gradeFeedback").val()
                };

                const btn = $("#btnGradeSubmit");
                btn.prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-1"></i> Kaydediliyor...');

                $.ajax({
                    url: `${API_BASE}/${subId}/grade`,
                    method: "POST",
                    contentType: "application/json",
                    data: JSON.stringify(data),
                    success: function () {
                        $("#gradeModal").modal("hide");
                        Swal.fire('Başarılı', 'Not başarıyla kaydedildi.', 'success');
                        loadSubmissions(currentPage);
                    },
                    complete: function () {
                        btn.prop("disabled", false).text("Puanı Kaydet");
                    }
                });
            });
        }

        function openGradeModal(id) {
            const sub = globalSubmissions.find(s => s.id === id);
            if (sub) {
                $("#gradeSubmissionId").val(sub.id);
                $("#gradeValue").val(sub.grade || '');
                $("#gradeFeedback").val(sub.feedback || '');
                $("#gradeModal").modal("show");
            }
        }
    </script>
}