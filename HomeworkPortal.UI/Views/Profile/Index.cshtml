@{
    ViewData["Title"] = "Profilim";
    var role = ViewBag.Role as string;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        <i class="fas fa-id-card mr-2 text-primary"></i>Yönetim Paneli
    </h1>
</div>

<!-- ================= GÖRÜNTÜLEME MODU ================= -->
<div id="viewProfileMode" class="row fade-in">
    <div class="col-12">
        <div class="card shadow mb-4">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white">
                <h6 class="m-0 font-weight-bold text-primary">Kullanıcı Profili</h6>
            </div>
            <div class="card-body">
                <div class="row">
                    <!-- Sol Taraf: Fotoğraf ve Rol -->
                    <div class="col-md-4 text-center border-right">
                        <img class="img-profile rounded-circle mb-3 shadow border border-primary p-1" src="~/Admin/img/undraw_profile.svg" alt="Profil" style="width: 160px; height: 160px; object-fit: cover;">
                        <h4 class="font-weight-bold text-dark mb-2" id="viewFullName">Yükleniyor...</h4>
                        <span class="badge badge-primary px-4 py-2 shadow-sm" id="viewRole" style="font-size: 0.9rem; border-radius: 20px;">Yükleniyor...</span>
                    </div>

                    <!-- Sağ Taraf: Kişisel Bilgiler -->
                    <div class="col-md-8 pl-md-5 mt-4 mt-md-0 d-flex flex-column justify-content-center">
                        <h5 class="font-weight-bold text-primary mb-4"><i class="fas fa-user-circle mr-2"></i>Kişisel Bilgiler</h5>

                        <div class="row mb-3">
                            <div class="col-sm-4 font-weight-bold text-gray-700">Ad Soyad:</div>
                            <div class="col-sm-8 text-dark" id="viewNameDetail">Yükleniyor...</div>
                        </div>
                        <div class="row mb-3">
                            <div class="col-sm-4 font-weight-bold text-gray-700">E-Posta Adresi:</div>
                            <div class="col-sm-8 text-dark" id="viewEmail">Yükleniyor...</div>
                        </div>
                        <hr>
                        <div class="text-right mt-3">
                            <button type="button" class="btn btn-warning font-weight-bold text-dark px-4 shadow-sm" id="btnEditMode">
                                <i class="fas fa-user-edit mr-2"></i>Bilgilerimi Güncelle
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- ================= DÜZENLEME MODU (Varsayılan Gizli) ================= -->
<div id="editProfileMode" class="row d-none fade-in">
    <div class="col-12">
        <div class="card shadow mb-4 border-left-warning">
            <div class="card-header py-3 d-flex flex-row align-items-center justify-content-between bg-white">
                <h6 class="m-0 font-weight-bold text-primary"><i class="fas fa-user-cog mr-2"></i>Kullanıcı ve Hesap İşlemleri</h6>
                <button class="btn btn-sm btn-secondary shadow-sm" id="btnViewMode">
                    <i class="fas fa-arrow-left mr-1"></i> Profile Dön
                </button>
            </div>
            <div class="card-body p-4">
                <form id="updateProfileForm">
                    <h5 class="font-weight-bold text-gray-700 mb-4 border-bottom pb-2">Hesap Bilgileri</h5>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="font-weight-bold text-gray-600">Adınız</label>
                            <input type="text" class="form-control" id="editFirstName" required>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="font-weight-bold text-gray-600">Soyadınız</label>
                            <input type="text" class="form-control" id="editLastName" required>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-md-6 form-group">
                            <label class="font-weight-bold text-gray-600">E-Posta Adresi <small class="text-danger">(Değiştirilemez)</small></label>
                            <input type="email" class="form-control bg-light" id="editEmail" readonly>
                        </div>
                        <div class="col-md-6 form-group">
                            <label class="font-weight-bold text-gray-600">Mevcut Rolünüz</label>
                            <input type="text" class="form-control bg-light" id="editRole" readonly>
                        </div>
                    </div>

                    <div class="row mt-3">
                        <div class="col-12 form-group">
                            <label class="font-weight-bold text-gray-600">Yeni Şifre <small class="text-primary">(Değiştirmek istemiyorsanız boş bırakın)</small></label>
                            <div class="input-group">
                                <input type="password" class="form-control border-right-0" id="editPassword" placeholder="Yeni şifrenizi buraya girin...">
                                <div class="input-group-append">
                                    <span class="input-group-text bg-white text-muted" id="togglePasswordVisibility" style="cursor: pointer;">
                                        <i class="fas fa-eye" id="togglePasswordIcon"></i>
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <hr class="mt-4 mb-4">

                    <div class="text-right">
                        <button type="button" class="btn btn-secondary mr-2" id="btnCancelEdit">İptal</button>
                        <button type="submit" class="btn btn-primary px-5 shadow-sm" id="btnSaveProfile">
                            <i class="fas fa-save mr-2"></i>Kaydet
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<style>
    .fade-in {
        animation: fadeIn 0.3s ease-in-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        $(document).ready(function() {
            let currentUserEmail = "";
            let currentFirstName = "";
            let currentLastName = "";

            // 1. TOKEN'DAN VERİLERİ OKUYUP EKRANA BASMA
            if (typeof jwtToken !== 'undefined' && jwtToken !== null && jwtToken !== "") {
                try {
                    const base64Url = jwtToken.split('.')[1];
                    const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/');
                    const jsonPayload = decodeURIComponent(atob(base64).split('').map(function(c) {
                        return '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2);
                    }).join(''));

                    const tokenData = JSON.parse(jsonPayload);

                    currentUserEmail = tokenData["http://schemas.xmlsoap.org/ws/2005/05/identity/claims/emailaddress"] || tokenData["email"] || "";
                    let fullName = tokenData["FullName"] || currentUserEmail.split('@@')[0];

                    let nameParts = fullName.split(' ');
                    currentFirstName = nameParts[0];
                    currentLastName = nameParts.length > 1 ? nameParts.slice(1).join(' ') : '';

                    let role = "@role";
                    let displayRole = role === "Student" ? "Öğrenci" : role === "Teacher" ? "Öğretmen" : "Sistem Yöneticisi";

                    $("#viewFullName").text(fullName);
                    $("#viewNameDetail").text(fullName);
                    $("#viewEmail").text(currentUserEmail);
                    $("#viewRole").text(displayRole);

                    $("#editFirstName").val(currentFirstName);
                    $("#editLastName").val(currentLastName);
                    $("#editEmail").val(currentUserEmail);
                    $("#editRole").val(displayRole);

                } catch (e) { console.error("Veri okuma hatası:", e); }
            }

            // 2. MODLAR ARASI GEÇİŞ (Görüntüleme <-> Düzenleme)
            $("#btnEditMode").click(function() {
                $("#viewProfileMode").addClass("d-none");
                $("#editProfileMode").removeClass("d-none");
            });

            $("#btnViewMode, #btnCancelEdit").click(function() {
                $("#editProfileMode").addClass("d-none");
                $("#viewProfileMode").removeClass("d-none");
                $("#editPassword").val("");
            });

            // 3. KAYDET BUTONU İŞLEMİ
            $("#updateProfileForm").on("submit", function(e) {
                e.preventDefault();

                let updatedData = {
                    firstName: $("#editFirstName").val(),
                    lastName: $("#editLastName").val(),
                    newPassword: $("#editPassword").val()
                };

                $.ajax({
                    url: "https://localhost:7113/api/Auth/update-profile",
                    method: "PUT",
                    contentType: "application/json",
                    data: JSON.stringify(updatedData),
                    beforeSend: function () {
                        $("#btnSaveProfile").prop("disabled", true).html('<i class="fas fa-spinner fa-spin mr-2"></i>Kaydediliyor...');
                    },
                    success: function (res) {
                        Swal.fire({ icon: 'success', title: 'Başarılı', text: 'Profiliniz başarıyla güncellendi!' });

                        $("#viewFullName").text(res.fullName);
                        $("#viewNameDetail").text(res.fullName);

                        $("#editProfileMode").addClass("d-none");
                        $("#viewProfileMode").removeClass("d-none");

                        $("#editPassword").val("");
                    },
                    error: function (err) {
                        let errorMsg = "İşlem sırasında bir hata oluştu.";
                        if (err.responseJSON && err.responseJSON.message) errorMsg = err.responseJSON.message;
                        Swal.fire({ icon: 'error', title: 'Hata', text: errorMsg });
                    },
                    complete: function () {
                        $("#btnSaveProfile").prop("disabled", false).html('<i class="fas fa-save mr-2"></i>Kaydet');
                    }
                });
            });

            // 4. ŞİFRE GÖSTER/GİZLE İŞLEMİ
            $("#togglePasswordVisibility").click(function() {
                let passwordInput = $("#editPassword");
                let icon = $("#togglePasswordIcon");

                if (passwordInput.attr("type") === "password") {
                    passwordInput.attr("type", "text");
                    icon.removeClass("fa-eye").addClass("fa-eye-slash");
                }
                else {
                    passwordInput.attr("type", "password");
                    icon.removeClass("fa-eye-slash").addClass("fa-eye");
                }
            });
        });
    </script>
}