@{
    ViewData["Title"] = "Ödevler";
    var role = ViewBag.Role as string;
    var courseId = ViewBag.CourseId;
}

<div class="d-sm-flex align-items-center justify-content-between mb-4">
    <h1 class="h3 mb-0 text-gray-800">
        @if (role == "Student")
        {
            <text>Bana Atanan Tüm Ödevler</text>
        }
        else
        {
            <text>Ödev Yönetimi</text>
        }
    </h1>

    @if (role == "Teacher" || role == "Admin")
    {
        <button class="d-none d-sm-inline-block btn btn-sm btn-primary shadow-sm" data-toggle="modal" data-target="#assignmentModal">
            <i class="fas fa-plus fa-sm text-white-50"></i> Yeni Ödev Ver
        </button>
    }
</div>

<div class="card shadow mb-4 border-left-primary">
    <div class="card-body py-3">
        <div class="row">
            <div class="col-md-4 mb-2 mb-md-0">
                <label class="small font-weight-bold text-primary"><i class="fas fa-filter mr-1"></i>Kurs Filtresi</label>
                <select id="courseFilterDropdown" class="form-control form-control-sm">
                    <option value="ALL">Tüm Kurslar (Karışık)</option>
                </select>
            </div>
            <div class="col-md-4 mb-2 mb-md-0">
                <label class="small font-weight-bold text-primary"><i class="fas fa-sort mr-1"></i>Sıralama</label>
                <select id="sortDropdown" class="form-control form-control-sm">
                    <option value="date_asc">Yaklaşan Teslim Tarihi (Önce)</option>
                    <option value="date_desc">Uzak Teslim Tarihi (Önce)</option>
                    <option value="title_asc">Ödev Başlığı (A-Z)</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="small font-weight-bold text-primary"><i class="fas fa-search mr-1"></i>Arama</label>
                <input type="text" id="searchInput" class="form-control form-control-sm" placeholder="Ödev adında ara...">
            </div>
        </div>
    </div>
</div>

<ul class="nav nav-tabs" id="assignmentTabs" role="tablist">
    <li class="nav-item">
        <a class="nav-link active font-weight-bold text-success" id="active-tab" data-toggle="tab" href="#activeTab" role="tab">
            <i class="fas fa-clock mr-1"></i> Aktif Ödevler
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link font-weight-bold text-danger" id="expired-tab" data-toggle="tab" href="#expiredTab" role="tab">
            <i class="fas fa-exclamation-circle mr-1"></i> Süresi Geçenler
        </a>
    </li>
</ul>

<div class="card shadow mb-4 border-top-0">
    <div class="card-body">
        <div class="tab-content">
            <!-- AKTİF ÖDEVLER TABLOSU -->
            <div class="tab-pane fade show active" id="activeTab" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0" width="100%" cellspacing="0">
                        <thead class="thead-dark">
                            <tr>
                                <th>İlgili Kurs</th>
                                <th>Ödev Başlığı</th>
                                <th>Açıklama</th>
                                <th>Son Teslim Tarihi</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="activeAssignmentsTableBody">
                            <tr><td colspan="6" class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Yükleniyor...</td></tr>
                        </tbody>
                    </table>
                </div>
                <!-- Aktif Ödevler Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3 px-2">
                    <div id="activePageInfo" class="small font-weight-bold text-muted"></div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0" id="activePagination"></ul>
                    </nav>
                </div>
            </div>

            <!-- SÜRESİ GEÇENLER TABLOSU -->
            <div class="tab-pane fade" id="expiredTab" role="tabpanel">
                <div class="table-responsive">
                    <table class="table table-bordered table-hover align-middle mb-0" width="100%" cellspacing="0">
                        <thead class="thead-dark">
                            <tr>
                                <th>İlgili Kurs</th>
                                <th>Ödev Başlığı</th>
                                <th>Açıklama</th>
                                <th>Son Teslim Tarihi</th>
                                <th>Durum</th>
                                <th>İşlem</th>
                            </tr>
                        </thead>
                        <tbody id="expiredAssignmentsTableBody">
                            <tr><td colspan="6" class="text-center text-muted py-4"><i class="fas fa-spinner fa-spin mr-2"></i>Yükleniyor...</td></tr>
                        </tbody>
                    </table>
                </div>
                <!-- Süresi Geçenler Sayfalama -->
                <div class="d-flex justify-content-between align-items-center mt-3 px-2">
                    <div id="expiredPageInfo" class="small font-weight-bold text-muted"></div>
                    <nav aria-label="Page navigation">
                        <ul class="pagination pagination-sm mb-0" id="expiredPagination"></ul>
                    </nav>
                </div>
            </div>
        </div>
    </div>
</div>

@if (role == "Teacher" || role == "Admin")
{
    <div class="modal fade" id="assignmentModal" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Yeni Ödev Bilgileri</h5>
                    <button type="button" class="close text-white" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="assignmentForm">
                        <div class="form-group">
                            <label class="font-weight-bold">Hangi Kursa Verilecek?</label>
                            <select id="assignCourseId" class="form-control" required>
                                <option value="">Lütfen Kurs Seçin...</option>
                            </select>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Başlık</label>
                            <input type="text" id="assignTitle" class="form-control" required placeholder="Örn: 1. Vize Ödevi">
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Açıklama</label>
                            <textarea id="assignDesc" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Son Teslim Tarihi</label>
                            <input type="datetime-local" id="assignDueDate" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary btn-block" id="btnSave">Ödevi Yayınla</button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <div class="modal fade" id="editAssignmentModal" data-backdrop="static" data-keyboard="false" tabindex="-1" role="dialog" aria-hidden="true">
        <div class="modal-dialog" role="document">
            <div class="modal-content">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">Ödevi Düzenle</h5>
                    <button type="button" class="close" data-dismiss="modal" aria-label="Close">
                        <span aria-hidden="true">&times;</span>
                    </button>
                </div>
                <div class="modal-body">
                    <form id="editAssignmentForm">
                        <input type="hidden" id="editAssignId">
                        <input type="hidden" id="editAssignCourseId">
                        <input type="hidden" id="editAssignRowVersion">
                        <div class="form-group">
                            <label class="font-weight-bold">Başlık</label>
                            <input type="text" id="editAssignTitle" class="form-control" required>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Açıklama</label>
                            <textarea id="editAssignDesc" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="form-group">
                            <label class="font-weight-bold">Son Teslim Tarihi</label>
                            <input type="datetime-local" id="editAssignDueDate" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-warning btn-block font-weight-bold" id="btnUpdate">Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/moment.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/moment.js/2.29.4/locale/tr.min.js"></script>

    <script>
        const API_BASE = "https://localhost:7113/api/Assignments";
        const COURSE_API = "https://localhost:7113/api/Courses";
        const USER_ROLE = "@role";

        let CURRENT_COURSE_ID = "@courseId" !== "" ? parseInt("@courseId") : null;
        let globalAllAssignments = [];
        let coursesMap = {};
        let courseStudentCounts = {};
        let assignmentSubmissionCounts = {};

        const PAGE_SIZE = 5;
        let currentActiveAssignments = [];
        let currentExpiredAssignments = [];
        let activePage = 1;
        let expiredPage = 1;

        $(document).ready(function () {
            moment.locale('tr');
            loadInitialData();

            $("#courseFilterDropdown, #sortDropdown").on("change", applyFiltersAndRender);
            $("#searchInput").on("keyup", applyFiltersAndRender);

            handleFormSubmissions();
        });

        async function loadInitialData() {
            try {
                $("#activeAssignmentsTableBody, #expiredAssignmentsTableBody").html('<tr><td colspan="6" class="text-center py-4"><i class="fas fa-spinner fa-spin text-primary mr-2"></i>Veriler analiz ediliyor...</td></tr>');

                const courseRes = await $.ajax({ url: COURSE_API, method: "GET" });
                const courses = courseRes.data || courseRes;

                $("#courseFilterDropdown").empty().append('<option value="ALL">Tüm Kurslar (Karışık)</option>');
                $("#assignCourseId").empty().append('<option value="">Lütfen Kurs Seçin...</option>');

                courses.forEach(c => {
                    coursesMap[c.id] = c.name;
                    $("#courseFilterDropdown").append(`<option value="${c.id}">${c.name}</option>`);
                    $("#assignCourseId").append(`<option value="${c.id}">${c.name}</option>`);
                });

                if(CURRENT_COURSE_ID) $("#courseFilterDropdown").val(CURRENT_COURSE_ID);

                if (USER_ROLE === "Student") {
                    const res = await $.ajax({ url: `${API_BASE}/student?pageNumber=1&pageSize=1000`, method: "GET" });
                    globalAllAssignments = res.data || res;
                } else {
                    const fetchPromises = courses.map(c =>
                        $.ajax({ url: `${API_BASE}/course/${c.id}?pageNumber=1&pageSize=1000`, method: "GET" }).catch(() => ({ data: [] }))
                    );
                    const results = await Promise.all(fetchPromises);
                    globalAllAssignments = [];
                    results.forEach(res => {
                        const list = res.data || res;
                        if(Array.isArray(list)) globalAllAssignments.push(...list);
                    });

                    await fetchManagementData(courses);
                }

                applyFiltersAndRender();

            } catch (err) {
                handleError(err);
                $("#activeAssignmentsTableBody, #expiredAssignmentsTableBody").html('<tr><td colspan="6" class="text-center text-danger">Veriler toplanırken hata oluştu!</td></tr>');
            }
        }

        async function fetchManagementData(courses) {
            const studentCountPromises = courses.map(c =>
                $.ajax({ url: `${COURSE_API}/${c.id}/students`, method: "GET" })
                .then(st => { courseStudentCounts[c.id] = (st.data || st).length; })
                .catch(() => { courseStudentCounts[c.id] = 0; })
            );

            const submissionCountPromises = globalAllAssignments.map(a =>
                $.ajax({ url: `https://localhost:7113/api/Submissions/assignment/${a.id}`, method: "GET" })
                .then(sub => { assignmentSubmissionCounts[a.id] = (sub.data || sub).length; })
                .catch(() => { assignmentSubmissionCounts[a.id] = 0; })
            );

            await Promise.all([...studentCountPromises, ...submissionCountPromises]);
        }

        function applyFiltersAndRender() {
            let filtered = [...globalAllAssignments];

            const selectedCourse = $("#courseFilterDropdown").val();
            if (selectedCourse !== "ALL") filtered = filtered.filter(a => a.courseId === parseInt(selectedCourse));

            const searchText = $("#searchInput").val().toLowerCase();
            if (searchText) filtered = filtered.filter(a => a.title.toLowerCase().includes(searchText) || a.description.toLowerCase().includes(searchText));

            const sortBy = $("#sortDropdown").val();
            filtered.sort((a, b) => {
                if (sortBy === "date_asc") return new Date(a.dueDate) - new Date(b.dueDate);
                if (sortBy === "date_desc") return new Date(b.dueDate) - new Date(a.dueDate);
                if (sortBy === "title_asc") return a.title.localeCompare(b.title);
                return 0;
            });

            const now = moment();

            currentActiveAssignments = filtered.filter(a => moment(a.dueDate).isSameOrAfter(now));
            currentExpiredAssignments = filtered.filter(a => moment(a.dueDate).isBefore(now));
            activePage = 1;
            expiredPage = 1;

            renderActivePage();
            renderExpiredPage();
        }

        // --- SAYFALAMA (PAGINATION) MOTORU ---

        function renderActivePage() {
            const total = currentActiveAssignments.length;
            const totalPages = Math.ceil(total / PAGE_SIZE) || 1;
            const start = (activePage - 1) * PAGE_SIZE;
            const paginatedData = currentActiveAssignments.slice(start, start + PAGE_SIZE);

            renderTableData(paginatedData, "#activeAssignmentsTableBody", true);
            renderPaginationControls(total, activePage, totalPages, "active");
        }

        function renderExpiredPage() {
            const total = currentExpiredAssignments.length;
            const totalPages = Math.ceil(total / PAGE_SIZE) || 1;
            const start = (expiredPage - 1) * PAGE_SIZE;
            const paginatedData = currentExpiredAssignments.slice(start, start + PAGE_SIZE);

            renderTableData(paginatedData, "#expiredAssignmentsTableBody", false);
            renderPaginationControls(total, expiredPage, totalPages, "expired");
        }

        function changePage(tab, page) {
            if (tab === 'active') {
                activePage = page;
                renderActivePage();
            } else {
                expiredPage = page;
                renderExpiredPage();
            }
        }

        function renderPaginationControls(totalCount, currentPage, totalPages, tab) {
            const container = tab === "active" ? "#activePagination" : "#expiredPagination";
            const infoContainer = tab === "active" ? "#activePageInfo" : "#expiredPageInfo";

            if (totalCount === 0) {
                $(container).html("");
                $(infoContainer).text("");
                return;
            }

            let html = "";
            html += `<li class="page-item ${currentPage === 1 ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage('${tab}', ${currentPage - 1})">Önceki</a>
                     </li>`;

            for (let i = 1; i <= totalPages; i++) {
                html += `<li class="page-item ${i === currentPage ? 'active' : ''}">
                            <a class="page-link" href="javascript:void(0)" onclick="changePage('${tab}', ${i})">${i}</a>
                         </li>`;
            }

            html += `<li class="page-item ${currentPage === totalPages ? 'disabled' : ''}">
                        <a class="page-link" href="javascript:void(0)" onclick="changePage('${tab}', ${currentPage + 1})">Sonraki</a>
                     </li>`;

            $(container).html(html);

            const startItem = (currentPage - 1) * PAGE_SIZE + 1;
            const endItem = Math.min(currentPage * PAGE_SIZE, totalCount);
            $(infoContainer).text(`Toplam ${totalCount} ödevden ${startItem}-${endItem} arası gösteriliyor.`);
        }

        // --- RENDER ---

        function renderTableData(assignments, targetTbody, isActive) {
            if (assignments.length === 0) {
                $(targetTbody).html('<tr><td colspan="6" class="text-center text-muted py-4">Kriterlere uygun ödev bulunamadı.</td></tr>');
                return;
            }

            let html = "";
            assignments.forEach(item => {
                const dueDateObj = new Date(item.dueDate);
                const dateText = dueDateObj.toLocaleString('tr-TR', { dateStyle: 'short', timeStyle: 'short' });
                const dateBadge = !isActive ? `<span class="text-danger font-weight-bold"><i class="fas fa-clock mr-1"></i>${dateText} (Bitti)</span>` : `<span class="text-success font-weight-bold"><i class="fas fa-clock mr-1"></i>${dateText}</span>`;
                const courseName = coursesMap[item.courseId] || "Bilinmeyen Kurs";

                let statusHtml = "";
                if (USER_ROLE === "Admin" || USER_ROLE === "Teacher") {
                    const submitted = assignmentSubmissionCounts[item.id] || 0;
                    const total = courseStudentCounts[item.courseId] || 0;
                    const colorClass = submitted === total && total > 0 ? "badge-success" : (submitted === 0 ? "badge-danger" : "badge-info");
                    statusHtml = `<span class="badge ${colorClass} px-3 py-2" style="font-size: 1rem;"><i class="fas fa-user-check mr-1"></i> ${submitted} / ${total}</span>`;
                } else {
                    if (item.isSubmitted) {
                        statusHtml = item.grade !== null ? `<span class="badge badge-success px-3 py-2">Yapıldı (${item.grade})</span>` : `<span class="badge badge-warning text-dark px-3 py-2">Not Bekliyor</span>`;
                    } else {
                        statusHtml = !isActive ? `<span class="badge badge-danger px-3 py-2">Kaçırıldı</span>` : `<span class="badge badge-secondary px-3 py-2">Yapılmadı</span>`;
                    }
                }

                html += `
                    <tr>
                        <td><span class="badge badge-primary p-2">${courseName}</span></td>
                        <td><strong class="text-dark">${item.title}</strong></td>
                        <td class="text-muted small">${item.description}</td>
                        <td>${dateBadge}</td>
                        <td class="text-center">${statusHtml}</td>
                        <td>${renderActions(item, !isActive)}</td>
                    </tr>`;
            });

            $(targetTbody).hide().html(html).fadeIn(200);
        }

        function renderActions(item, isExpired) {
            let actions = "";
            if (USER_ROLE === "Admin" || USER_ROLE === "Teacher") {
                actions += `<a href="/Submissions?assignmentId=${item.id}" class="btn btn-sm btn-info text-white mr-1" title="Teslimleri Gör"><i class="fas fa-eye"></i></a>`;
                actions += `<button class="btn btn-sm btn-warning text-dark mr-1" onclick="openEditModal(${item.id})"><i class="fas fa-edit"></i></button>`;
                actions += `<button class="btn btn-sm btn-danger" onclick="deleteAssignment(${item.id})"><i class="fas fa-trash"></i></button>`;
            } else {
                if (isExpired) actions += `<button class="btn btn-sm btn-secondary" disabled><i class="fas fa-lock"></i></button>`;
                else actions += `<a href="/Submissions?assignmentId=${item.id}" class="btn btn-sm btn-success"><i class="fas fa-upload mr-1"></i>Yükle</a>`;
            }
            return actions;
        }

        function openEditModal(id) {
            const assignment = globalAllAssignments.find(a => a.id === id);
            if (assignment) {
                $("#editAssignId").val(assignment.id);
                $("#editAssignTitle").val(assignment.title);
                $("#editAssignDesc").val(assignment.description);
                $("#editAssignCourseId").val(assignment.courseId);
                $("#editAssignRowVersion").val(assignment.rowVersion);
                const date = new Date(assignment.dueDate);
                const tzoffset = date.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(date - tzoffset)).toISOString().slice(0, 16);
                $("#editAssignDueDate").val(localISOTime);
                $("#editAssignmentModal").modal("show");
            }
        }

        function handleFormSubmissions() {
            $("#assignmentForm").on("submit", function (e) {
                e.preventDefault();
                const data = { title: $("#assignTitle").val(), description: $("#assignDesc").val(), dueDate: $("#assignDueDate").val(), courseId: parseInt($("#assignCourseId").val()) };
                $.ajax({
                    url: API_BASE, method: "POST", contentType: "application/json", data: JSON.stringify(data),
                    beforeSend: function () { $("#btnSave").prop("disabled", true).text("Yayınlanıyor..."); },
                    success: function () { $("#assignmentModal").modal("hide"); $("#assignmentForm")[0].reset(); showToast("Başarılı", "Ödev yayınlandı.", "success"); loadInitialData(); },
                    error: function (err) { handleError(err); },
                    complete: function () { $("#btnSave").prop("disabled", false).text("Ödevi Yayınla"); }
                });
            });

            $("#editAssignmentForm").on("submit", function (e) {
                e.preventDefault();
                const id = parseInt($("#editAssignId").val());
                const data = { id: id, title: $("#editAssignTitle").val(), description: $("#editAssignDesc").val(), dueDate: $("#editAssignDueDate").val(), courseId: parseInt($("#editAssignCourseId").val()), rowVersion: $("#editAssignRowVersion").val() };
                $.ajax({
                    url: `${API_BASE}/${id}`, method: "PUT", contentType: "application/json", data: JSON.stringify(data),
                    beforeSend: function () { $("#btnUpdate").prop("disabled", true).text("Güncelleniyor..."); },
                    success: function () { $("#editAssignmentModal").modal("hide"); showToast("Başarılı", "Ödev güncellendi.", "success"); loadInitialData(); },
                    error: function (err) { handleError(err); },
                    complete: function () { $("#btnUpdate").prop("disabled", false).text("Güncelle"); }
                });
            });
        }

        function deleteAssignment(id) {
            Swal.fire({
                title: 'Emin misiniz?', text: "Tüm teslimatlar silinecektir!", icon: 'warning',
                showCancelButton: true, confirmButtonColor: '#e74a3b', confirmButtonText: 'Evet, Sil!'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({ url: `${API_BASE}/${id}`, method: "DELETE", success: function() { showToast("Silindi", "Ödev silindi.", "danger"); loadInitialData(); }, error: function(err) { handleError(err); } });
                }
            });
        }

        function handleError(err) {
            let errorMsg = "Hata oluştu.";
            if (err.responseJSON) errorMsg = err.responseJSON.message || err.responseJSON.detail || "İşlem başarısız.";
            showToast("Hata", errorMsg, "danger");
        }

        function showToast(title, message, type) {
            Swal.mixin({
                toast: true, position: 'bottom-end', showConfirmButton: false, timer: 3000,
                timerProgressBar: true, background: type === 'danger' ? '#e74a3b' : (type === 'success' ? '#1cc88a' : '#f6c23e'), color: '#fff'
            }).fire({ icon: type === 'danger' ? 'error' : type, title: title, text: message });
        }
    </script>
}