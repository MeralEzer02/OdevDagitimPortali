@{
    ViewData["Title"] = "Ödevler";
    var role = ViewBag.Role as string;
    var courseId = ViewBag.CourseId;
}

<div class="card border-0 shadow-sm mb-4 bg-light">
    <div class="card-body p-3">
        <div class="row g-3">
            <div class="col-md-4">
                <label class="form-label text-muted mb-1"><i class="fa fa-filter me-2"></i>Kurs Filtresi</label>
                <select id="courseFilterDropdown" class="form-select border-primary shadow-none">
                    <option value="ALL">Tüm Kurslar (Karışık)</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted mb-1"><i class="fa fa-sort me-2"></i>Sıralama</label>
                <select id="sortDropdown" class="form-select border-primary shadow-none">
                    <option value="date_asc">Yaklaşan Teslim Tarihi (Önce)</option>
                    <option value="date_desc">Uzak Teslim Tarihi (Önce)</option>
                    <option value="title_asc">Ödev Başlığı (A-Z)</option>
                </select>
            </div>
            <div class="col-md-4">
                <label class="form-label text-muted mb-1"><i class="fa fa-search me-2"></i>Arama</label>
                <input type="text" id="searchInput" class="form-control border-primary shadow-none" placeholder="Ödevin adında veya içeriğinde ara...">
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <div class="col-12">
        <div class="bg-light rounded h-100 p-4 shadow-sm">
            <div class="d-flex align-items-center justify-content-between mb-4">
                <h6 class="mb-0" id="pageTitle">
                    @if (role == "Student")
                    {
                        <text>Tüm Ödevlerim</text>
                    }
                    else
                    {

                        <text>Yönetim Paneli - Tüm Ödevler</text>
                    }
                </h6>

                @if (role == "Teacher" || role == "Admin")
                {
                    <button class="btn btn-primary d-none" id="btnOpenModal" data-bs-toggle="modal" data-bs-target="#assignmentModal">
                        <i class="fa fa-plus me-2"></i>Yeni Ödev Ver
                    </button>
                }
            </div>

            <div class="table-responsive">
                <table class="table text-start align-middle table-bordered table-hover mb-0">
                    <thead class="table-dark">
                        <tr>
                            <th scope="col">İlgili Kurs</th>
                            <th scope="col">Ödev Başlığı</th>
                            <th scope="col">Açıklama</th>
                            <th scope="col">Son Teslim Tarihi</th>
                            <th scope="col">İşlem</th>
                        </tr>
                    </thead>
                    <tbody id="assignmentTableBody">
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@* Ödev Verme Modalı *@
@if (role == "Teacher" || role == "Admin")
{
    <div class="modal fade" id="assignmentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title">Yeni Ödev Bilgileri</h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="assignmentForm">
                        <div class="mb-3">
                            <label class="form-label fw-bold">Hangi Kursa Verilecek?</label>
                            <select id="assignCourseId" class="form-select" required>
                                <option value="">Lütfen Kurs Seçin...</option>
                            </select>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Başlık</label>
                            <input type="text" id="assignTitle" class="form-control" required placeholder="Örn: 1. Vize Ödevi">
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Açıklama</label>
                            <textarea id="assignDesc" class="form-control" rows="3" required placeholder="Ödevin detayları..."></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Son Teslim Tarihi</label>
                            <input type="datetime-local" id="assignDueDate" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-primary w-100" id="btnSave">Ödevi Yayınla <i class="fa fa-paper-plane ms-2"></i></button>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* Ödev Düzenleme Modalı *@
    <div class="modal fade" id="editAssignmentModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog">
            <div class="modal-content border-0 shadow">
                <div class="modal-header bg-warning text-dark">
                    <h5 class="modal-title">Ödevi Düzenle</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="editAssignmentForm">
                        <input type="hidden" id="editAssignId">
                        <input type="hidden" id="editAssignCourseId">

                        <div class="mb-3">
                            <label class="form-label fw-bold">Başlık</label>
                            <input type="text" id="editAssignTitle" class="form-control" required>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Açıklama</label>
                            <textarea id="editAssignDesc" class="form-control" rows="3" required></textarea>
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">Son Teslim Tarihi</label>
                            <input type="datetime-local" id="editAssignDueDate" class="form-control" required>
                        </div>
                        <button type="submit" class="btn btn-warning w-100 fw-bold" id="btnUpdate">Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
}

@section Scripts {
    <script>
        const API_BASE = "https://localhost:7113/api/Assignments";
        const COURSE_API = "https://localhost:7113/api/Courses";
        const USER_ROLE = "@role";

        let CURRENT_COURSE_ID = "@courseId" !== "" ? parseInt("@courseId") : null;

        // Front-End Zekası: Tüm veriyi burada toplayıp, anlık filtreleyeceğiz
        let globalAllAssignments = [];
        let coursesMap = {};

        $(document).ready(function () {

            if(USER_ROLE === "Teacher" || USER_ROLE === "Admin") {
                 $("#btnOpenModal").removeClass("d-none");
            }

            // Sayfa açılır açılmaz verileri topla
            loadInitialData();

            // FİLTRELERİ DİNLE (Değiştikçe tabloyu anında yenile)
            $("#courseFilterDropdown, #sortDropdown").on("change", applyFiltersAndRender);
            $("#searchInput").on("keyup", applyFiltersAndRender);

            // YENİ ÖDEV VERME
            if ($("#assignmentForm").length) {
                $("#assignmentForm").on("submit", function (e) {
                    e.preventDefault();
                    const data = {
                        title: $("#assignTitle").val(),
                        description: $("#assignDesc").val(),
                        dueDate: $("#assignDueDate").val(),
                        courseId: parseInt($("#assignCourseId").val()) // Kurs artık modaldan seçiliyor!
                    };

                    $.ajax({
                        url: API_BASE,
                        method: "POST",
                        contentType: "application/json",
                        data: JSON.stringify(data),
                        beforeSend: function () { $("#btnSave").prop("disabled", true).text("Yayınlanıyor..."); },
                        success: function () {
                            $("#assignmentModal").modal("hide");
                            $("#assignmentForm")[0].reset();
                            showToast("Başarılı", "Ödev başarıyla yayınlandı.", "success");
                            loadInitialData(); // Tüm veriyi baştan çek ve yenile
                        },
                        error: function (err) { handleError(err); },
                        complete: function () { $("#btnSave").prop("disabled", false).html('Ödevi Yayınla <i class="fa fa-paper-plane ms-2"></i>'); }
                    });
                });
            }

            // ÖDEV GÜNCELLEME
            if ($("#editAssignmentForm").length) {
                $("#editAssignmentForm").on("submit", function (e) {
                    e.preventDefault();
                    const id = parseInt($("#editAssignId").val());
                    const data = {
                        id: id,
                        title: $("#editAssignTitle").val(),
                        description: $("#editAssignDesc").val(),
                        dueDate: $("#editAssignDueDate").val(),
                        courseId: parseInt($("#editAssignCourseId").val())
                    };

                    $.ajax({
                        url: `${API_BASE}/${id}`,
                        method: "PUT",
                        contentType: "application/json",
                        data: JSON.stringify(data),
                        beforeSend: function () { $("#btnUpdate").prop("disabled", true).text("Güncelleniyor..."); },
                        success: function () {
                            $("#editAssignmentModal").modal("hide");
                            showToast("Başarılı", "Ödev başarıyla güncellendi.", "success");
                            loadInitialData();
                        },
                        error: function (err) { handleError(err); },
                        complete: function () { $("#btnUpdate").prop("disabled", false).text("Güncelle"); }
                    });
                });
            }
        });

        // 🚀 BÜYÜK FRONT-END BÜYÜSÜ: BÜTÜN VERİLERİ TEK SEFERDE TOPLUYORUZ
        async function loadInitialData() {
            try {
                $("#assignmentTableBody").html('<tr><td colspan="5" class="text-center py-4"><div class="spinner-border text-primary spinner-border-sm mb-2"></div><br>Ödevler tüm kurslardan toplanıyor, lütfen bekleyin...</td></tr>');

                // 1. Önce Kursları Çek
                const courseRes = await $.ajax({ url: COURSE_API, method: "GET" });
                const courses = courseRes.data || courseRes;

                // Dropdownları temizle ve doldur
                $("#courseFilterDropdown").empty().append('<option value="ALL">Tüm Kurslar (Karışık)</option>');
                $("#assignCourseId").empty().append('<option value="">Lütfen Kurs Seçin...</option>');

                courses.forEach(c => {
                    coursesMap[c.id] = c.name; // ID'den isme hızlı erişim için sözlük oluştur
                    $("#courseFilterDropdown").append(`<option value="${c.id}">${c.name}</option>`);
                    $("#assignCourseId").append(`<option value="${c.id}">${c.name}</option>`);
                });

                // Eğer "Kurslar" sayfasından geldiysek o kursu otomatik seçili yap
                if(CURRENT_COURSE_ID) {
                    $("#courseFilterDropdown").val(CURRENT_COURSE_ID);
                }

                // 2. Ödevleri Çek
                if (USER_ROLE === "Student") {
                    const res = await $.ajax({ url: `${API_BASE}/student`, method: "GET" });
                    globalAllAssignments = res.data || res;
                } else {
                    // Hoca/Admin ise: Her bir kurs için API'ye paralel istek (Promise.all) at!
                    const fetchPromises = courses.map(c =>
                        $.ajax({ url: `${API_BASE}/course/${c.id}`, method: "GET" })
                         .catch(err => ({ data: [] })) // Boş olan veya hata verenleri atla
                    );
                    const results = await Promise.all(fetchPromises);

                    globalAllAssignments = [];
                    results.forEach(res => {
                        const list = res.data || res;
                        if(Array.isArray(list)) globalAllAssignments.push(...list);
                    });
                }

                // Veriler hazır, anında ekrana bas!
                applyFiltersAndRender();

            } catch (err) {
                handleError(err);
                $("#assignmentTableBody").html('<tr><td colspan="5" class="text-center text-danger">Veriler toplanırken hata oluştu!</td></tr>');
            }
        }

        // 🚀 ANLIK FİLTRELEME VE EKRANA ÇİZME
        function applyFiltersAndRender() {
            // Ana listeyi bozmadan kopyasını alıyoruz
            let filtered = [...globalAllAssignments];

            // 1. Kurs Filtresi
            const selectedCourse = $("#courseFilterDropdown").val();
            if (selectedCourse !== "ALL") {
                filtered = filtered.filter(a => a.courseId === parseInt(selectedCourse));
            }

            // 2. Kelime Araması (Hem başlık hem açıklamada arar)
            const searchText = $("#searchInput").val().toLowerCase();
            if (searchText) {
                filtered = filtered.filter(a => a.title.toLowerCase().includes(searchText) || a.description.toLowerCase().includes(searchText));
            }

            // 3. Sıralama
            const sortBy = $("#sortDropdown").val();
            filtered.sort((a, b) => {
                if (sortBy === "date_asc") return new Date(a.dueDate) - new Date(b.dueDate);
                if (sortBy === "date_desc") return new Date(b.dueDate) - new Date(a.dueDate);
                if (sortBy === "title_asc") return a.title.localeCompare(b.title);
                return 0;
            });

            // 4. HTML'i Oluştur
            let html = "";
            if (filtered.length === 0) {
                html = '<tr><td colspan="5" class="text-center text-muted py-5"><i class="fa fa-folder-open fs-1 mb-3"></i><br>Aradığınız kriterlere uygun ödev bulunamadı.</td></tr>';
            } else {
                filtered.forEach(item => {
                    const dueDateObj = new Date(item.dueDate);
                    const isExpired = dueDateObj < new Date();
                    const dateText = dueDateObj.toLocaleString('tr-TR', { dateStyle: 'short', timeStyle: 'short' });
                    const dateBadge = isExpired ? `<span class="badge bg-danger"><i class="fa fa-clock me-1"></i>${dateText} (Bitti)</span>` : `<span class="badge bg-success"><i class="fa fa-clock me-1"></i>${dateText}</span>`;

                    const courseName = coursesMap[item.courseId] || "Bilinmeyen Kurs";

                    html += `
                        <tr>
                            <td><span class="badge border border-primary text-primary">${courseName}</span></td>
                            <td><strong>${item.title}</strong></td>
                            <td>${item.description}</td>
                            <td>${dateBadge}</td>
                            <td>${renderActions(item, isExpired)}</td>
                        </tr>`;
                });
            }
            $("#assignmentTableBody").html(html);
        }

        // DÜZENLE MODALINI AÇ (Tarih formatı dönüştürülerek)
        function openEditModal(id) {
            const assignment = globalAllAssignments.find(a => a.id === id);
            if (assignment) {
                $("#editAssignId").val(assignment.id);
                $("#editAssignTitle").val(assignment.title);
                $("#editAssignDesc").val(assignment.description);
                $("#editAssignCourseId").val(assignment.courseId);

                // C#'tan gelen ISO tarihini input[type=datetime-local] formatına uydurma hilesi
                const date = new Date(assignment.dueDate);
                const tzoffset = date.getTimezoneOffset() * 60000;
                const localISOTime = (new Date(date - tzoffset)).toISOString().slice(0, 16);

                $("#editAssignDueDate").val(localISOTime);
                $("#editAssignmentModal").modal("show");
            }
        }

        function renderActions(item, isExpired) {
            let actions = "";

            if (USER_ROLE === "Admin" || USER_ROLE === "Teacher") {
                actions += `<a href="/Submissions?assignmentId=${item.id}" class="btn btn-sm btn-info me-1 text-white"><i class="fa fa-eye"></i> Teslimler</a>`;
                actions += `<button class="btn btn-sm btn-warning me-1" onclick="openEditModal(${item.id})"><i class="fa fa-edit"></i></button>`;
                actions += `<button class="btn btn-sm btn-danger" onclick="deleteAssignment(${item.id})"><i class="fa fa-trash"></i></button>`;
            }
            else if (USER_ROLE === "Student") {
                if(isExpired) {
                    actions += `<button class="btn btn-sm btn-secondary" disabled><i class="fa fa-lock me-1"></i>Süre Bitti</button>`;
                } else {
                    actions += `<a href="/Submissions/Submit?assignmentId=${item.id}" class="btn btn-sm btn-success"><i class="fa fa-upload me-1"></i>Yükle</a>`;
                }
            }

            return actions;
        }

        function deleteAssignment(id) {
            if(confirm("Bu ödevi silmek istediğinize emin misiniz? Öğrencilerin yüklediği dosyalar da silinebilir!")) {
                $.ajax({
                    url: `${API_BASE}/${id}`,
                    method: "DELETE",
                    success: function() {
                        showToast("Silindi", "Ödev başarıyla silindi.", "success");
                        loadInitialData();
                    },
                    error: function(err) { handleError(err); }
                });
            }
        }

        // GELİŞMİŞ HATA YAKALAYICI
        function handleError(err) {
            let errorMsg = "İşlem sırasında beklenmeyen bir hata oluştu.";
            console.error("API'DEN GELEN HATA RÖNTGENİ:", err);

            if (err.responseJSON) {
                if (err.responseJSON.errors) {
                    errorMsg = Object.values(err.responseJSON.errors).flat().join("<br>");
                } else if (err.responseJSON.detail) {
                    errorMsg = err.responseJSON.detail;
                } else if (err.responseJSON.message) {
                    errorMsg = err.responseJSON.message;
                } else if (err.responseJSON.title) {
                    errorMsg = err.responseJSON.title;
                }
            } else if (err.status === 403) {
                errorMsg = "Bu işlemi gerçekleştirmek için yetkiniz yok.";
            } else if (err.responseText) {
                errorMsg = "Sunucu Hatası: " + err.statusText;
            }

            showToast("İşlem Başarısız", errorMsg, "danger");
        }   

        function showToast(title, message, type) {
            const toastHtml = `
                <div class="toast align-items-center text-white bg-${type} border-0 position-fixed top-0 end-0 m-3" role="alert" aria-live="assertive" aria-atomic="true" style="z-index: 1055;">
                  <div class="d-flex">
                    <div class="toast-body">
                      <strong>${title}</strong><br/> ${message}
                    </div>
                    <button type="button" class="btn-close btn-close-white me-2 m-auto" data-bs-dismiss="toast" aria-label="Close"></button>
                  </div>
                </div>
            `;
            $("body").append(toastHtml);
            const toastEl = $(".toast").last();
            const toast = new bootstrap.Toast(toastEl[0], { delay: 4000 });
            toast.show();
            toastEl.on('hidden.bs.toast', function () { $(this).remove(); });
        }
    </script>
}